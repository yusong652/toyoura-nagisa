# toyoura-nagisa Environment Configuration
# Copy this to .env and fill in your API keys
# Google/Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Anthropic/Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Development Configuration
APP_DEBUG=false

# Development Server Configuration
ENVIRONMENT=development
DEV_HOST=0.0.0.0
DEV_PORT=8000
DEV_ENABLE_RELOAD=true
DEV_DEBUG=false
DEV_LOG_LEVEL=INFO

# CORS Configuration
# Additional allowed origins (comma-separated)
# Example for production: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Leave empty in development to use default localhost ports
CORS_ALLOWED_ORIGINS=
