{
  "name": "ainagisa",
  "version": "1.0.0",
  "description": "An AI-powered chat assistant with multi-turn conversation memory and voice output capabilities",
  "main": "index.js",
  "scripts": {
    "install:frontend": "cd frontend-react && npm install",
    "start:frontend": "cd frontend-react && npm run dev",
    "install:backend": "cd backend && uv pip install -r requirements.txt",
    "lint:backend": "cd backend && ruff check .",
    "format:backend": "cd backend && ruff format .",
    "start:backend": "cd backend && uv run run.py",
    "start:mcp": "cd backend/nagisa_mcp && uv run fast_mcp_server.py",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\" \"npm run start:mcp\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yusong652/aiNagisa.git"
  },
  "keywords": [],
