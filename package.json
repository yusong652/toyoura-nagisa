{
  "name": "ainagisa",
  "version": "1.0.0",
  "description": "An AI-powered chat assistant with multi-turn conversation memory and voice output capabilities",
  "private": true,
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "main": "index.js",
  "scripts": {
    "install:frontend": "cd frontend && npm install",
    "start:frontend": "cd frontend && npm run dev",
    "install:backend": "cd backend && uv pip install -r requirements.txt",
    "lint:backend": "cd backend && ruff check .",
    "format:backend": "cd backend && ruff format .",
    "start:backend": "PYTHONUNBUFFERED=1 uv run python backend/run.py",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build:core": "cd packages/core && npm run build",
    "build:cli": "cd packages/core && npm run build && cd ../cli && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yusong652/aiNagisa.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/yusong652/aiNagisa/issues"
  },
  "homepage": "https://github.com/yusong652/aiNagisa#readme",
  "devDependencies": {
    "@google/gemini-cli": "^0.1.7",
    "concurrently": "^9.2.0"
  }
}
