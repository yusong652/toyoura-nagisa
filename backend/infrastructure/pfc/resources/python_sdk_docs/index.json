  "fallback_hints": {
    "batch creation": "For creating many balls with packing patterns, use itasca.command('ball generate ...')",
    "cubic packing": "Python SDK doesn't support cubic packing. Use itasca.command('ball generate cubic ...')",
    "hexagonal packing": "Python SDK doesn't support hexagonal packing. Use itasca.command('ball generate hexagonal ...')",
    "model solve": "For solving to equilibrium, use itasca.command('model solve'). Python SDK has itasca.cycle() for fixed cycles only.",
