  "common_tasks": {
    "monitor stress in region": {
      "functions": ["itasca.measure.find", "Measure.stress"],
      "example": "measure = itasca.measure.find(1); stress = measure.stress()"
    },
    "track porosity": {
      "functions": ["itasca.measure.find", "Measure.porosity"],
      "example": "measure = itasca.measure.find(1); por = measure.porosity()"
    },
    "measure coordination number": {
      "functions": ["itasca.measure.find", "Measure.coordination"],
