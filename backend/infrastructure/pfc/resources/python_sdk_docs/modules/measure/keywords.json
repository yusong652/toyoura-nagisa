      "functions": ["itasca.measure.find", "Measure.size"],
      "example": "measure = itasca.measure.find(1); dist = measure.size()"
    },
    "iterate all measurements": {
      "functions": ["itasca.measure.list"],
      "example": "for m in itasca.measure.list(): print(m.stress())"
    },
    "move measurement sphere": {
      "functions": ["Measure.set_pos"],
      "example": "measure.set_pos(vec(10, 10, 10))"
    },
    "resize measurement sphere": {
      "functions": ["Measure.set_radius"],
      "example": "measure.set_radius(3.0)"
    }
