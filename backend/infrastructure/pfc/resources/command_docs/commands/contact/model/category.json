{
  "category": "contact model",
  "parent_category": "contact",
  "full_name": "Contact Model Commands",
  "description": "Commands for assigning and configuring contact models that define mechanical behavior at contact points",
  "command_prefix": "contact model",
  "python_module": "itasca.contact",
  "python_object_method": "Contact.set_model(), Contact.model()",
  "doc_url": "https://docs.itascacg.com/pfc700/pfc/docproject/source/manual/contact/commands/cmd_contact.model.html",
  "commands": [
    {
      "name": "assign",
      "file": "assign.json",
      "short_description": "Assign contact models to contacts",
      "syntax": "contact model assign <model_name> <range>",
      "python_available": true,
      "python_alternative": "Contact.set_model() - requires iteration",
      "use_cases": ["Set default contact model", "Assign models to groups", "Batch model assignment"],
      "priority": "high"
    },
    {
      "name": "linear",
      "file": "linear.json",
      "short_description": "Configure linear contact model (elastic, frictional)",
      "syntax": "contact model linear [property <value>]...",
      "python_available": "partial",
      "python_alternative": "Contact.set_prop() after assigning 'linear' model",
      "use_cases": ["Set linear elastic behavior", "Configure friction"],
      "priority": "high"
    },
    {
      "name": "linearpbond",
      "file": "linearpbond.json",
      "short_description": "Configure linear parallel bond model",
      "syntax": "contact model linearpbond [property <value>]...",
      "python_available": "partial",
      "python_alternative": "Contact.set_prop() after assigning 'linearpbond' model",
      "use_cases": ["Create bonded materials", "Simulate cemented particles"],
      "priority": "high"
    },
    {
      "name": "linearcbond",
      "file": "linearcbond.json",
      "short_description": "Configure linear contact bond model",
      "syntax": "contact model linearcbond [property <value>]...",
      "python_available": "partial",
      "python_alternative": "Contact.set_prop() after assigning 'linearcbond' model",
      "use_cases": ["Create contact-based bonds", "Simulate adhesion"],
      "priority": "medium"
    },
    {
      "name": "hertz",
      "file": "hertz.json",
      "short_description": "Configure Hertz contact model (non-linear elastic)",
      "syntax": "contact model hertz [property <value>]...",
      "python_available": "partial",
      "python_alternative": "Contact.set_prop() after assigning 'hertz' model",
      "use_cases": ["Non-linear elasticity", "More realistic contact behavior"],
      "priority": "medium"
    },
    {
      "name": "null",
      "file": "null.json",
      "short_description": "Remove contact model (no forces transmitted)",
      "syntax": "contact model null <range>",
      "python_available": true,
      "python_alternative": "Contact.set_model(None)",
      "use_cases": ["Disable contacts", "Remove contact forces"],
      "priority": "low"
    }
  ],
  "available_models": [
    "linear",
    "linearpbond",
    "linearcbond",
    "hertz",
    "rrlinear",
    "null"
  ],
  "common_properties": {
    "kn": "Normal stiffness (for linear models)",
    "ks": "Shear stiffness (for linear models)",
    "fric": "Friction coefficient",
    "pb_kn": "Parallel bond normal stiffness",
    "pb_ks": "Parallel bond shear stiffness",
    "pb_ten": "Parallel bond tensile strength",
    "pb_coh": "Parallel bond cohesion"
  },
  "related_categories": ["ball", "wall", "clump"],
  "notes": [
    "Contact models must be assigned before setting model-specific properties",
    "Each contact model has its own set of properties",
    "Default contact model can be set globally or per-range",
    "Use 'contact model assign' for bulk operations instead of Python iteration"
  ]
}
