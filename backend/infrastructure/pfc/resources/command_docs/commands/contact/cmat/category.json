  "what_is_cmat": "The Contact Model Assignment Table (CMAT) is a table of rules that automatically assigns contact models and properties when contacts are created. Each CMAT entry defines which contact model and properties to use for contacts that match a specific range criterion.",
  "common_keywords": {
    "model": "Specify which contact model to assign",
    "property": "Set contact model properties",
    "inheritance": "Control property inheritance behavior",
    "method": "Register contact model methods to invoke at creation",
    "proximity": "Set contact detection distance",
    "mechanical": "Apply to mechanical contacts",
    "thermal": "Apply to thermal contacts"
  },
  "available_models": [
    "linear",
    "linearpbond",
    "linearcbond",
    "hertz",
    "rrlinear",
    "arrlinear",
    "bilinear",
    "burger",
    "fish",
    "flatjoint",
    "hysteretic",
    "lineardipole",
    "smoothjoint",
    "softbond",
    "null"
  ],
  "model_properties_reference": {
    "path": "../model-properties/index.json",
    "description": "See model-properties documentation for detailed property information for each contact model"
  },
  "related_categories": ["contact", "contact model", "ball", "wall"],
  "notes": [
    "CMAT entries are evaluated in order when contacts are created",
    "If no CMAT entry matches, the default entry is used",
    "Range specification is mandatory for CMAT add command",
    "Entry index i=0 is reserved for the default entry",
    "Use lower indices for more specific rules (they're checked first)"
  ]
