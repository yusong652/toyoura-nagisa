  "commands": [
    {
      "name": "add",
      "file": "add.json",
      "short_description": "Add a new entry to the CMAT",
      "syntax": "contact cmat add <i> keyword ... range",
      "python_available": false,
      "python_alternative": "itasca.command('contact cmat add ...')",
      "use_cases": ["Define contact model rules", "Set default contact properties", "Configure contact behavior by range"],
      "priority": "high",
      "status": "documented"
    },
    {
      "name": "apply",
      "file": "apply.json",
      "short_description": "Apply CMAT to existing contacts",
      "syntax": "contact cmat apply <keyword> <range>",
      "python_available": false,
      "python_alternative": "itasca.command('contact cmat apply ...')",
