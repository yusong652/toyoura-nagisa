{
  "category": "wall",
  "full_name": "Wall Commands",
  "description": "Commands for creating, modifying, and managing wall objects (faceted boundaries) in PFC",
  "command_prefix": "wall",
  "python_module": "itasca.wall",
  "python_object_class": "Wall",
  "doc_url": "https://docs.itascacg.com/pfc700/pfc/docproject/source/manual/wall/wall.html",
  "commands": [
    {
      "name": "create",
      "file": "create.json",
      "short_description": "Create walls by specifying vertices directly",
      "syntax": "wall create vertices <v1> <v2> <v3> ...",
      "python_available": "partial",
      "python_alternative": "Complex manual vertex creation using Python SDK",
      "use_cases": ["Create custom wall shapes", "Define boundary conditions"],
      "priority": "medium"
    },
    {
      "name": "generate",
      "file": "generate.json",
      "short_description": "Generate walls with standard geometries (box, cylinder, cone, etc.)",
      "syntax": "wall generate <keyword> <parameters>",
      "python_available": false,
      "python_alternative": "Manual vertex calculation and wall creation",
      "use_cases": ["Create simulation boundaries", "Box containers", "Cylindrical chambers"],
      "priority": "high"
    },
    {
      "name": "delete",
      "file": "delete.json",
      "short_description": "Delete walls based on range specification",
      "syntax": "wall delete <range>",
      "python_available": "partial",
      "python_alternative": "Wall.delete() - requires iteration",
      "use_cases": ["Remove specific walls", "Delete by group"],
      "priority": "medium"
    },
    {
      "name": "attribute",
      "file": "attribute.json",
      "short_description": "Set wall attributes (velocity, displacement, etc.)",
      "syntax": "wall attribute <keyword> <value> <range>",
      "python_available": true,
      "python_alternative": "Wall.set_* methods (e.g., Wall.set_vel())",
      "use_cases": ["Move walls", "Apply velocities", "Set wall properties"],
      "priority": "high"
    },
    {
      "name": "property",
      "file": "property.json",
      "short_description": "Set wall surface properties",
      "syntax": "wall property <name> <value> <range>",
      "python_available": true,
      "python_alternative": "Wall.set_prop()",
      "use_cases": ["Set contact properties", "Material properties for wall facets"],
      "priority": "medium"
    },
    {
      "name": "group",
      "file": "group.json",
      "short_description": "Assign walls to groups",
      "syntax": "wall group <slot> <name> <range>",
      "python_available": true,
      "python_alternative": "Wall.set_group()",
      "use_cases": ["Organize walls", "Range selection"],
      "priority": "low"
    },
    {
      "name": "result",
      "file": "result.json",
      "short_description": "Query wall results and calculate aggregate values",
      "syntax": "wall result <keyword> <range>",
      "python_available": "partial",
      "python_alternative": "Wall getter methods - requires manual aggregation",
      "use_cases": ["Get wall forces", "Sum contact forces", "Query wall properties"],
      "priority": "low"
    }
  ],
  "common_ranges": {
    "all": "All walls in the model",
    "group <name>": "Walls in the specified group",
    "id <n>": "Wall with specific ID",
    "name <string>": "Wall with specific name"
  },
  "related_categories": ["ball", "clump", "contact", "model"],
  "notes": [
    "Walls are composed of triangular facets (Facet objects)",
    "Wall generation commands (box, cylinder) are not available in Python SDK",
    "Use Python SDK for programmatic wall manipulation",
    "Walls can be moved via velocity or displacement attributes"
  ]
}
