    "contact": {
      "full_name": "Contact Commands",
      "description": "Commands for configuring contact models and managing contact properties between objects",
      "command_prefix": "contact",
      "python_module": "itasca.contact",
      "python_object_class": "Contact (BallBallContact, BallFacetContact, etc.)",
      "doc_url": "https://docs.itascacg.com/pfc700/pfc/docproject/source/manual/contact/contact.html",
      "priority": "high",
      "model_properties_reference": {
        "path": "commands/contact/model-properties/index.json",
        "description": "Detailed properties reference for all contact models. Contains comprehensive documentation of each model's properties including types, ranges, defaults, and usage patterns.",
        "use_when": "Need to know available properties for a contact model, valid ranges, or typical values"
      },
      "commands": [
        {
          "name": "model",
          "file": "commands/contact/model.json",
          "short_description": "Assign contact model to existing contacts",
          "syntax": "contact model <keyword> <range>",
          "python_available": true,
          "python_alternative": "Contact.set_model(model_name) - requires iteration",
          "use_cases": ["Change contact model type", "Switch to bonded model", "Disable contacts with null model", "Change to nonlinear model"],
          "priority": "high",
          "status": "documented"
        },
        {
          "name": "cmat",
          "description": "Contact Model Assignment Table (CMAT) management",
          "file": "commands/contact/cmat/",
          "commands": ["add", "apply", "default", "list", "modify", "proximity", "remove"],
          "priority": "high"
        },
        {
          "name": "property",
          "file": "commands/contact/property.json",
          "short_description": "Set contact model properties for existing contacts",
          "syntax": "contact property <keyword> ... <inheritance b> ... <range>",
          "python_available": true,
          "python_alternative": "Contact.set_prop(property_name, value) - requires iteration",
          "use_cases": ["Update bond strengths", "Add damping", "Modify stiffnesses", "Change friction", "Calibrate parameters"],
          "priority": "high",
          "status": "documented"
        },
        {
          "name": "activate",
          "file": "commands/contact/activate.json",
          "short_description": "Control contact activation state",
          "syntax": "contact activate <b> <keyword> <range>",
          "python_available": true,
          "python_alternative": "Contact.activate(flag) - requires iteration",
          "use_cases": ["Force contacts to stay active", "Override model activity logic", "Prevent contact deactivation"],
          "priority": "medium",
          "status": "documented"
        },
        {
          "name": "inhibit",
          "file": "commands/contact/inhibit.json",
          "short_description": "Inhibit (disable) contacts temporarily",
          "syntax": "contact inhibit <bval> <keyword> <range>",
          "python_available": true,
          "python_alternative": "Contact.set_inhibit(flag), inhibit()",
          "use_cases": ["Temporarily disable contacts", "Test scenarios without deletion", "Selective contact disabling"],
          "priority": "medium",
          "status": "documented"
        },
        {
          "name": "group",
          "file": "commands/contact/group.json",
          "short_description": "Assign contacts to groups",
          "syntax": "contact group <s> <keyword> ... <range>",
          "python_available": true,
          "python_alternative": "Contact.set_group(), group(), group_remove(), groups(), in_group()",
          "use_cases": ["Organize contacts", "Range selection", "Multiple classification schemes"],
          "priority": "low",
          "status": "documented"
        },
        {
          "name": "method",
          "file": "commands/contact/method.json",
          "short_description": "Execute contact model methods",
          "syntax": "contact method <method_name> <args> <range>",
          "python_available": true,
          "python_alternative": "Contact.method()",
          "use_cases": ["Bond contacts", "Activate special behaviors"],
          "priority": "medium",
          "status": "documented"
        },
        {
          "name": "delete",
          "file": "commands/contact/delete.json",
          "short_description": "Delete contacts in specified range",
          "syntax": "contact delete <range>",
          "python_available": false,
          "python_alternative": "itasca.command('contact delete range ...') - no direct SDK method",
          "use_cases": ["Remove inactive contacts", "Break bonds", "Clean up contacts", "Reset contact system"],
          "priority": "medium",
          "status": "documented"
        },
        {
          "name": "detection",
          "file": "commands/contact/detection.json",
          "short_description": "Control automatic contact detection on/off",
          "syntax": "contact detection <b> <keyword>",
          "python_available": false,
          "python_alternative": "itasca.command('contact detection ...') - no direct SDK method",
          "use_cases": ["Freeze contact network", "Manual contact control", "Prevent automatic changes", "Type-specific detection control"],
          "priority": "high",
          "status": "documented"
        }
      ],
      "common_ranges": {
        "all": "All contacts in the model",
        "group <name>": "Contacts in the specified group",
        "model <model_name>": "Contacts with specific contact model",
        "type <contact_type>": "Contacts of specific type (e.g., ball-ball)",
        "contact <id1> <id2>": "Contact between two specific objects"
      },
      "related_categories": ["ball", "wall", "clump", "model"],
      "notes": [
        "Contact models define mechanical behavior at contact points",
        "Common contact models: linear, linearpbond, linearcbond, hertz",
        "Contact properties are model-specific (e.g., 'kn' for normal stiffness)",
        "Use 'contact model' commands to assign and configure models"
      ]
    },
    "model": {
      "full_name": "Model Commands",
      "description": "System-level commands for controlling simulation execution, configuration, and state management",
      "command_prefix": "model",
      "python_module": "itasca",
      "python_functions": ["itasca.cycle(), itasca.timestep(), itasca.set_timestep()"],
      "doc_url": "https://docs.itascacg.com/pfc700/pfc/docproject/source/manual/model/model.html",
      "priority": "high",
      "commands": [
        {
          "name": "solve",
          "file": "commands/model/solve.json",
          "short_description": "Solve to mechanical equilibrium using convergence criteria",
          "syntax": "model solve [ratio <value>] [ratio-average <value>] ...",
          "python_available": false,
          "python_alternative": "itasca.cycle() with manual ratio checking in loop",
          "use_cases": ["Reach equilibrium automatically", "Solve to force/moment balance", "Automatic timestep adjustment"],
          "priority": "high"
        },
        {
          "name": "cycle",
          "file": "commands/model/cycle.json",
          "short_description": "Execute a specified number of calculation cycles",
          "syntax": "model cycle <n>",
          "python_available": true,
          "python_alternative": "itasca.cycle(n)",
          "use_cases": ["Fixed number of timesteps", "Manual simulation control"],
          "priority": "high"
        },
        {
          "name": "configure",
          "file": "commands/model/configure.json",
          "short_description": "Configure model settings and options",
          "syntax": "model configure <keyword>",
          "python_available": "partial",
          "python_alternative": "Various itasca.set_* functions",
          "use_cases": ["Set thread count", "Enable features", "Configure solver"],
          "priority": "medium"
        },
        {
          "name": "domain",
          "file": "commands/model/domain.json",
          "short_description": "Define computational domain and boundary conditions",
          "syntax": "model domain <keyword> <parameters>",
          "python_available": true,
          "python_alternative": "itasca.set_domain_min(), itasca.set_domain_max(), itasca.set_domain_condition()",
          "use_cases": ["Set periodic boundaries", "Define domain extent", "Boundary conditions"],
          "priority": "high"
        },
        {
          "name": "save",
          "file": "commands/model/save.json",
          "short_description": "Save model state to file",
          "syntax": "model save <filename>",
          "python_available": false,
          "python_alternative": "Use itasca.command('model save <filename>')",
          "use_cases": ["Checkpoint simulations", "Save results", "Create restart points"],
          "priority": "medium"
        },
        {
          "name": "restore",
          "file": "commands/model/restore.json",
          "short_description": "Restore model state from file",
          "syntax": "model restore <filename>",
          "python_available": false,
          "python_alternative": "Use itasca.command('model restore <filename>')",
          "use_cases": ["Load checkpoints", "Continue simulations", "Load initial states"],
          "priority": "medium"
        }
      ],
      "common_keywords": {
        "solve": ["ratio", "ratio-average", "force-max", "moment-max", "cycles"],
        "cycle": ["number of cycles"],
        "domain": ["extent", "condition", "periodic", "destroy"],
        "configure": ["threads", "dynamic"]
      },
      "related_categories": ["ball", "wall", "contact", "set"],
      "notes": [
        "'model solve' is preferred for reaching equilibrium (not available in Python SDK)",
        "'model cycle' is equivalent to itasca.cycle() in Python",
        "Model state can be saved/restored for checkpointing",
        "Domain settings must be configured before generating objects",
        "Use 'model solve' with ratio criteria for automatic convergence"
      ]
    },
