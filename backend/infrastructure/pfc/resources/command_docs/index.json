      "doc_url": "https://docs.itascacg.com/pfc700/pfc/docproject/source/manual/ball/ball.html",
      "priority": "high",
      "commands": [
        {
          "name": "generate",
          "file": "commands/ball/generate.json",
          "short_description": "Generate balls with various packing patterns (cubic, hexagonal, etc.)",
          "syntax": "ball generate <keyword> <range> [keywords...]",
          "python_available": false,
          "python_alternative": "itasca.ball.create() - individual ball creation only",
          "use_cases": ["Batch ball creation", "Packing patterns", "Initial assemblies"],
          "priority": "high"
        },
        {
          "name": "delete",
          "file": "commands/ball/delete.json",
          "short_description": "Delete balls based on range specification",
          "syntax": "ball delete <range>",
          "python_available": "partial",
          "python_alternative": "Ball.delete() - requires iteration",
          "use_cases": ["Remove specific balls", "Clear regions", "Delete by group"],
          "priority": "high"
        },
        {
          "name": "attribute",
          "file": "commands/ball/attribute.json",
          "short_description": "Set ball attributes (density, displacement, force, etc.)",
          "syntax": "ball attribute <keyword> <value> <range>",
          "python_available": true,
          "python_alternative": "Ball.set_* methods (e.g., Ball.set_density())",
          "use_cases": ["Bulk property updates", "Initialize ball states", "Apply forces"],
          "priority": "high"
        },
        {
          "name": "property",
          "file": "commands/ball/property.json",
          "short_description": "Set ball surface properties",
          "syntax": "ball property <name> <value> <range>",
          "python_available": true,
          "python_alternative": "Ball.set_prop()",
          "use_cases": ["Set contact properties", "Material properties"],
          "priority": "medium"
        },
        {
          "name": "group",
          "file": "commands/ball/group.json",
          "short_description": "Assign balls to groups",
          "syntax": "ball group <slot> <name> <range>",
          "python_available": true,
          "python_alternative": "Ball.set_group()",
          "use_cases": ["Organize balls", "Range selection", "Apply operations to subsets"],
          "priority": "medium"
        },
        {
          "name": "result",
          "file": "commands/ball/result.json",
          "short_description": "Query ball results and calculate aggregate values",
          "syntax": "ball result <keyword> <range>",
          "python_available": "partial",
          "python_alternative": "Ball getter methods - requires manual aggregation",
          "use_cases": ["Get maximum values", "Sum forces", "Count balls in range"],
          "priority": "medium"
        },
        {
          "name": "history",
          "file": "commands/ball/history.json",
          "short_description": "Track ball properties over time",
          "syntax": "ball history <keyword> <id>",
          "python_available": false,
          "python_alternative": "Manual tracking with Python callbacks",
          "use_cases": ["Monitor ball motion", "Track forces", "Record velocities"],
          "priority": "low"
        }
      ],
      "common_ranges": {
        "all": "All balls in the model",
        "group <name>": "Balls in the specified group",
        "id <n>": "Ball with specific ID",
        "box <x1 y1 z1> <x2 y2 z2>": "Balls within bounding box",
        "radius <rmin> <rmax>": "Balls with radius in range"
      },
      "related_categories": ["wall", "clump", "contact", "model"],
      "notes": [
        "Ball commands typically operate on ranges (groups, spatial regions, or all balls)",
        "Use Python SDK for fine-grained control and complex logic",
        "Use commands for batch operations and initial model setup",
        "Ball generation with packing patterns requires commands (not available in Python SDK)"
      ]
    },
