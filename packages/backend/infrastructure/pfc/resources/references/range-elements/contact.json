{
  "name": "contact",
  "category": "pfc_specific",
  "category_name": "PFC-Specific Elements",
  "syntax": "contact [active|inactive|all] [gap <f1> [f2]] [model <s>] [type <s>]",
  "description": "Filter contacts by activity state, gap distance, contact model, or type.",
  "parameters": [
    {
      "name": "active/inactive/all",
      "type": "keyword",
      "description": "Activity filter (default: all)"
    },
    {
      "name": "gap",
      "type": "float",
      "description": "Gap range. Single value: <= gap; two values: f1 <= gap <= f2"
    },
    {
      "name": "model",
      "type": "string",
      "description": "Contact model name (linear, hertz, etc.)"
    },
    {
      "name": "type",
      "type": "string",
      "description": "Contact type (ball-ball, ball-wall, etc.)"
    }
  ],
  "examples": [
    "range contact active",
    "range contact gap 0 0.01",
    "range contact model 'linear'",
    "range contact type 'ball-ball'"
  ],
  "search_keywords": [
    "contact",
    "contact"
  ]
}