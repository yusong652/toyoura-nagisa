{
  "name": "@aiNagisa/cli",
  "version": "0.1.0",
  "description": "Command-line interface for aiNagisa AI assistant",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ainagisa": "./dist/index.js",
    "nagisa": "./dist/index.js"
  },
  "scripts": {
    "dev": "node --import tsx src/index.tsx",
    "build": "tsc",
    "bundle": "esbuild src/index.tsx --bundle --platform=node --format=esm --outfile=dist/bundle.js --external:@aiNagisa/core",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["aiNagisa", "cli", "ai", "assistant"],
  "author": "aiNagisa Team",
  "license": "MIT",
  "dependencies": {
    "@aiNagisa/core": "*",
    "ansi-escapes": "^7.0.0",
    "ink": "npm:@jrichman/ink@6.4.6",
    "ink-spinner": "^5.0.0",
    "react": "^19.0.0",
    "string-width": "^7.2.0",
    "strip-ansi": "^7.1.0",
    "wrap-ansi": "^9.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.5.13",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "tsx": "^4.20.3"
  },
  "engines": {
    "node": ">=20"
  }
}
