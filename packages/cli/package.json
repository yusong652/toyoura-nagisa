{
  "name": "@aiNagisa/cli",
  "version": "0.1.0",
  "description": "Command-line interface for aiNagisa AI assistant",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ainagisa": "./dist/index.js",
    "nagisa": "./dist/index.js"
  },
  "scripts": {
    "dev": "node --import tsx src/index.tsx",
    "dev:auto": "node --import tsx src/index.tsx --auto-backend",
    "build": "tsc",
    "bundle": "esbuild src/index.tsx --bundle --platform=node --format=esm --outfile=dist/bundle.js --external:@aiNagisa/core",
    "start": "node dist/index.js --auto-backend",
    "clean": "rm -rf dist"
  },
  "keywords": ["aiNagisa", "cli", "ai", "assistant"],
  "author": "aiNagisa Team",
  "license": "MIT",
  "dependencies": {
    "@aiNagisa/core": "*",
    "ink": "^4.4.1",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "esbuild": "^0.25.0",
    "typescript": "^5.3.3",
    "tsx": "^4.20.3"
  }
}
